{
  "manifest_version": 3,
  "name": "Capca — Screen Recorder",
  "version": "0.3.2",
  "minimum_chrome_version": "116",
  "description": "Record your screen, tab, or camera with a presenter bubble and share a link the moment you stop. Open source.",
  "permissions": [
    "offscreen",
    "scripting",
    "storage",
    "activeTab",
    "downloads"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_title": "Record with Capca"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["bubble.html", "bubble.js", "content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
