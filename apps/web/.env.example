# Postgres (docker-compose defaults)
DATABASE_URL=postgres://videocapture:videocapture@localhost:5433/videocapture

# Better Auth — generate a real secret: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:3000

# S3-compatible storage (docker-compose MinIO defaults; point at R2/S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=videocapture
S3_SECRET_ACCESS_KEY=videocapture
S3_BUCKET=recordings
# MinIO needs path-style URLs; set to false for AWS S3 / R2
S3_FORCE_PATH_STYLE=true
# Dev convenience: create the bucket on first use
S3_AUTO_CREATE_BUCKET=true
