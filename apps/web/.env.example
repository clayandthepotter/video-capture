# Postgres (docker-compose defaults)
DATABASE_URL=postgres://capca:capca@localhost:5433/capca

# Better Auth — generate a real secret: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:3000

# Social sign-in (optional — buttons work once these are set)
# Google: https://console.cloud.google.com/apis/credentials
#   redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: Settings -> Developer settings -> OAuth Apps
#   callback URL: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# S3-compatible storage (docker-compose MinIO defaults; point at R2/S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=capca
S3_SECRET_ACCESS_KEY=capca
S3_BUCKET=recordings
# MinIO needs path-style URLs; set to false for AWS S3 / R2
S3_FORCE_PATH_STYLE=true
# Dev convenience: create the bucket on first use
S3_AUTO_CREATE_BUCKET=true
